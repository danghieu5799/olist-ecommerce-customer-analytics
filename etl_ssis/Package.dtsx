            <SQLTask:SqlTaskData
              SQLTask:Connection="{A6AAC913-736F-4F81-8048-4199CE83216E}"
              SQLTask:SqlStatementSource="IF NOT EXISTS (SELECT 1 FROM dim_date)&#xA;BEGIN&#xA;&#xA;WITH dates AS (&#xA;    SELECT CAST('2016-01-01' AS DATE) AS d&#xA;    UNION ALL&#xA;    SELECT DATEADD(DAY, 1, d)&#xA;    FROM dates&#xA;    WHERE d &lt; '2019-12-31'&#xA;)&#xA;&#xA;INSERT INTO dim_date&#xA;SELECT&#xA;    CONVERT(INT, FORMAT(d, 'yyyyMMdd')),&#xA;    d,&#xA;    YEAR(d),&#xA;    MONTH(d),&#xA;    DAY(d),&#xA;    DATEPART(QUARTER, d)&#xA;FROM dates&#xA;OPTION (MAXRECURSION 10000);&#xA;&#xA;INSERT INTO dim_date&#xA;VALUES (-1, NULL, NULL, NULL, NULL, NULL);&#xA;&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
